# App
NEXT_PUBLIC_SITE_URL=https://rent.itshop.ng
# Do not set NODE_ENV manually. Next.js and Vercel set it automatically.

# Database
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_URL=postgresql://user:password@host/db?sslmode=require

# Admin auth
ADMIN_SESSION_SECRET=replace_with_a_32_plus_character_random_secret
BCRYPT_SALT_ROUNDS=12

# Bootstrap admin seed
ADMIN_SEED_NAME=ITShop Admin
ADMIN_SEED_EMAIL=admin@itshop.ng
ADMIN_SEED_PASSWORD=change-this-before-launch

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ITShop Rentals <rentals@itshop.ng>
ADMIN_ALERT_EMAIL=support@itshop.ng

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=...

# Cloudflare R2
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_PUBLIC_BUCKET=itshop-public
R2_PRIVATE_BUCKET=itshop-private
R2_PUBLIC_BASE_URL=https://assets.rent.itshop.ng

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=...
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=...
SANITY_REVALIDATE_SECRET=..
