generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  VIEWER
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
  INSTITUTION
}

enum CategoryStatus {
  ACTIVE
  REQUEST_ONLY
  COMING_SOON
  HIDDEN
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  REQUEST_ONLY
  COMING_SOON
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  OUT_FOR_DELIVERY
  RENTED
  AWAITING_RETURN
  RETURNED
  UNDER_INSPECTION
  DAMAGED
  LOST
  UNDER_MAINTENANCE
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  PAYMENT_PENDING
  PAID
  UNDER_REVIEW
  DOCUMENTS_REQUIRED
  APPROVED
  DEPOSIT_PENDING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  ACTIVE_RENTAL
  RETURN_DUE
  RETURNED_PENDING_INSPECTION
  CLOSED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  MANUAL_REVIEW
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  BANK_TRANSFER
}

enum PaymentMethod {
  CARD
  TRANSFER
  BANK_TRANSFER
}

enum DocumentReviewStatus {
  PENDING
  VALID
  INVALID
  NEEDS_RESUBMISSION
  SENT_BY_EMAIL
}

enum DeliveryStatus {
  NOT_READY
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum ReturnStatus {
  NOT_DUE
  DUE
  PICKUP_SCHEDULED
  RECEIVED
  UNDER_INSPECTION
  CLEARED
  DAMAGED
  LOST
}

model AdminUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         AdminRole  @default(ADMIN)
  isActive     Boolean    @default(true)
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

model Customer {
  id           String             @id @default(cuid())
  customerType CustomerType
  name         String
  companyName  String?
  contactName  String?
  phone        String
  email        String
  address      String?
  city         String?
  state        String?
  orders       RentalOrder[]
  documents    CustomerDocument[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([email])
  @@index([phone])
}

model Category {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?
  status         CategoryStatus @default(ACTIVE)
  seoTitle       String?
  seoDescription String?
  products       Product[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Product {
  id             String           @id @default(cuid())
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  name           String
  slug           String           @unique
  shortDesc      String?
  description    String?
  status         ProductStatus    @default(ACTIVE)
  rentable       Boolean          @default(true)
  sellable       Boolean          @default(false)
  images         ProductImage[]
  variants       ProductVariant[]
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@index([status])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  sortOrder Int     @default(0)
}

model ProductVariant {
  id              String            @id @default(cuid())
  productId       String
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  name            String
  slug            String            @unique
  brand           String?
  model           String?
  processor       String?
  ram             String?
  storage         String?
  operatingSystem String?
  screenSize      String?
  condition       String?
  dailyRate       Decimal           @db.Decimal(12, 2)
  weeklyRate      Decimal?          @db.Decimal(12, 2)
  monthlyRate     Decimal?          @db.Decimal(12, 2)
  availableQty    Int               @default(0)
  inventoryUnits  InventoryUnit[]
  orderItems      RentalOrderItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([productId])
}

model InventoryUnit {
  id        String          @id @default(cuid())
  variantId String
  variant   ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  serialNo  String?         @unique
  status    InventoryStatus @default(AVAILABLE)
  condition String?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([variantId])
  @@index([status])
}

model PricingRule {
  id                 String   @id @default(cuid())
  name               String
  minDaysSingleUnit  Int      @default(7)
  bulkThreshold      Int      @default(10)
  minDaysBulk        Int      @default(2)
  maxStandardDays    Int      @default(183)
  bulkDiscountRate   Decimal  @default(0.05) @db.Decimal(5, 4)
  deliveryFeeDefault Decimal  @default(0) @db.Decimal(12, 2)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RentalOrder {
  id                  String             @id @default(cuid())
  reference           String             @unique
  customerId          String
  customer            Customer           @relation(fields: [customerId], references: [id])
  status              OrderStatus        @default(SUBMITTED)
  paymentStatus       PaymentStatus      @default(PENDING)
  rentalStartDate     DateTime
  returnDate          DateTime
  rentalDays          Int
  deliveryAddress     String
  city                String?
  state               String?
  purpose             String?
  subtotal            Decimal            @db.Decimal(12, 2)
  discount            Decimal            @default(0) @db.Decimal(12, 2)
  deliveryFeeEstimate Decimal            @default(0) @db.Decimal(12, 2)
  total               Decimal            @db.Decimal(12, 2)
  agreementAccepted   Boolean            @default(false)
  adminNotes          String?
  items               RentalOrderItem[]
  payments            Payment[]
  documents           CustomerDocument[]
  delivery            Delivery?
  returnRecord        ReturnRecord?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([returnDate])
}

model RentalOrderItem {
  id         String         @id @default(cuid())
  orderId    String
  order      RentalOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  quantity   Int
  dailyRate  Decimal        @db.Decimal(12, 2)
  rentalDays Int
  subtotal   Decimal        @db.Decimal(12, 2)
}

model Payment {
  id          String          @id @default(cuid())
  orderId     String
  order       RentalOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    PaymentProvider
  method      PaymentMethod
  amount      Decimal         @db.Decimal(12, 2)
  status      PaymentStatus   @default(PENDING)
  reference   String          @unique
  rawResponse Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model CustomerDocument {
  id           String               @id @default(cuid())
  customerId   String
  customer     Customer             @relation(fields: [customerId], references: [id])
  orderId      String?
  order        RentalOrder?         @relation(fields: [orderId], references: [id])
  documentType String
  fileKey      String
  fileName     String
  mimeType     String
  sizeBytes    Int
  reviewStatus DocumentReviewStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([reviewStatus])
}

model Delivery {
  id          String         @id @default(cuid())
  orderId     String         @unique
  order       RentalOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      DeliveryStatus @default(NOT_READY)
  address     String
  city        String?
  state       String?
  scheduledAt DateTime?
  deliveredAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ReturnRecord {
  id          String       @id @default(cuid())
  orderId     String       @unique
  order       RentalOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      ReturnStatus @default(NOT_DUE)
  dueDate     DateTime
  receivedAt  DateTime?
  inspectionNotes String?
  damageFee   Decimal      @default(0) @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SpecialRequest {
  id           String   @id @default(cuid())
  name         String
  companyName  String?
  phone        String
  email        String
  city         String?
  state        String?
  quantity     Int?
  startDate    DateTime?
  returnDate   DateTime?
  requirements String
  status       String   @default("NEW")
  adminNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model BusinessSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
